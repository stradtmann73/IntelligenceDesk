---
interface Props {
  title?: string;
  message?: string;
  tone?: "stale" | "source_delayed";
}

const {
  title,
  message = "Source check delayed. Last verified content will appear here.",
  tone = "stale"
} = Astro.props as Props;

const resolvedTitle =
  title ??
  (tone === "source_delayed" ? "Verification delayed" : "Showing last verified context");
const label = tone === "source_delayed" ? "Delayed" : "Stale";
---

<article class:list={["stale-state-card", `stale-state-card--${tone}`]}>
  <span class="state-card__label">{label}</span>
  <h4>{resolvedTitle}</h4>
  <p>{message}</p>
</article>
